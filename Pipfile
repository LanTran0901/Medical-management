[[source]]
url = "https://pypi.org/simple"
verify_ssl = true
name = "pypi"

[packages]
fastapi = "*"
uvicorn = {extras = ["standard"], version = "*"}
motor = "*"
pydantic-settings = "*"
# PostgreSQL async
sqlalchemy = {extras = ["asyncio"], version = "*"}
asyncpg = "*"
greenlet = "*"
# Alembic migrations (uses psycopg2 sync engine internally)
alembic = "*"
psycopg2-binary = "*"
langgraph = "*"
langchain-groq = "*"

[dev-packages]

[requires]
python_version = "3.12"

[scripts]
start = "uvicorn app.main:app --host 0.0.0.0 --port 8080 --reload"
